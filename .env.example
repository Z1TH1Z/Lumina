# AI Financial Copilot - Environment Variables
# Copy this to .env and customize

# === App ===
APP_NAME=AI Financial Copilot
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-me-use-openssl-rand-hex-32

# === Database ===
DATABASE_URL=postgresql+asyncpg://fincopilot:fincopilot@localhost:5432/fincopilot
DATABASE_SYNC_URL=postgresql://fincopilot:fincopilot@localhost:5432/fincopilot
POSTGRES_USER=fincopilot
POSTGRES_PASSWORD=fincopilot
POSTGRES_DB=fincopilot

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === JWT ===
JWT_SECRET_KEY=jwt-secret-change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === Ollama LLM ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text

# === FAISS ===
FAISS_INDEX_PATH=./data/faiss_index

# === File Upload ===
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# === Celery ===
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# === PII Protection ===
PII_ENABLED=true

# === CORS ===
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
